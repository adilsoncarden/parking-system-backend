# Puerto del servidor (Render/Railway lo asigna automáticamente via $PORT)
PORT=8080

# Base de datos PostgreSQL (Neon.tech o cualquier PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/condosaas
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=tu_password

# CORS: orígenes permitidos (separados por coma si hay varios)
CORS_ALLOWED_ORIGINS=http://localhost:5173